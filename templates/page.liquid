{% section 'announcement-bar' %}
{% section 'header' %}
<main id="main-content">
  {%- case page.handle -%}
    {%- when 'ritual', 'the-ritual' -%}
      {% section 'ritual-page' %}
    {%- when 'our-story', 'story' -%}
      {% section 'story-page' %}
    {%- when 'founder', 'the-founder' -%}
      {% section 'founder-page' %}
    {%- when 'contact' -%}
      {% section 'contact-page' %}
    {%- else -%}
      <div class="page-section">
        <div class="page-inner">
          <h1 class="page-title">{{ page.title }}</h1>
          <div class="page-content rte">{{ page.content }}</div>
        </div>
      </div>
  {%- endcase -%}
</main>
{% section 'footer' %}

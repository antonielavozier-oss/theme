{% assign logo_cream = 'logo-cream.png' | asset_url %}
<footer class="site-footer" {% if section.settings.bg_color != blank %}style="background:{{ section.settings.bg_color }}"{% endif %}>
  <div class="footer-grid">

    <!-- Brand col -->
    <div>
      <div class="footer-logo">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: height: 52 }}" alt="{{ shop.name }}" height="26">
        {%- else -%}
          <img src="{{ logo_cream }}" alt="{{ shop.name }}" height="26">
        {%- endif -%}
      </div>
      <p class="footer-about">{{ section.settings.about | default: 'Ancient wisdom. Modern ritual. We provide the ingredients. You be the alchemist. Founded in Brussels, crafted with sustainably sourced botanicals for women everywhere.' }}</p>
      <div class="footer-social">
        {%- if section.settings.instagram != blank -%}
        <a href="{{ section.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        {%- endif -%}
        {%- if section.settings.tiktok != blank -%}
        <a href="{{ section.settings.tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.78a4.85 4.85 0 0 1-1.01-.09z"/></svg>
        </a>
        {%- endif -%}
        {%- if section.settings.pinterest != blank -%}
        <a href="{{ section.settings.pinterest }}" aria-label="Pinterest" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.22-5.17 1.22-5.17s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.33.67 1.33 1.48 0 .9-.58 2.26-.87 3.51-.25 1.05.52 1.9 1.55 1.9 1.86 0 3.1-2.4 3.1-5.24 0-2.16-1.46-3.78-4.1-3.78-2.99 0-4.85 2.23-4.85 4.72 0 .86.24 1.46.62 1.93.17.2.19.28.13.51-.04.17-.14.57-.18.73-.06.23-.24.32-.44.23-1.24-.51-1.82-1.88-1.82-3.41 0-2.53 2.14-5.58 6.39-5.58 3.42 0 5.67 2.48 5.67 5.14 0 3.52-1.96 6.17-4.83 6.17-.96 0-1.87-.52-2.18-1.1l-.59 2.32c-.21.82-.79 1.85-1.18 2.47.89.27 1.83.42 2.8.42 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
        </a>
        {%- endif -%}
        {%- if section.settings.youtube != blank -%}
        <a href="{{ section.settings.youtube }}" aria-label="YouTube" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23 7s-.3-2-1.2-2.8c-1.1-1.2-2.4-1.2-3-1.3C16.4 2.7 12 2.7 12 2.7s-4.4 0-6.8.2c-.6.1-1.9.1-3 1.3C1.3 5 1 7 1 7S.7 9.2.7 11.5v2.1c0 2.3.3 4.5.3 4.5s.3 2 1.2 2.8c1.1 1.2 2.6 1.1 3.3 1.2C7.3 22.3 12 22.3 12 22.3s4.4 0 6.8-.3c.6-.1 1.9-.1 3-1.3.9-.8 1.2-2.8 1.2-2.8s.3-2.2.3-4.5v-2c0-2.3-.3-4.5-.3-4.5zM9.7 15.5V8.4l8.1 3.6-8.1 3.5z"/></svg>
        </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Shop col -->
    <div class="footer-col">
      <h4>{{ section.settings.col2_title | default: 'Shop' }}</h4>
      <ul>
        {%- assign footer_col = collections['all'] -%}
        {%- for fp in footer_col.products limit: 6 -%}
          <li><a href="{{ fp.url }}">{{ fp.title }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    <!-- Brand col -->
    <div class="footer-col">
      <h4>{{ section.settings.col3_title | default: 'Archetype' }}</h4>
      <ul>
        {%- if section.settings.col3_link1_label != blank -%}<li><a href="{{ section.settings.col3_link1_url | default: '/pages/our-story' }}">{{ section.settings.col3_link1_label }}</a></li>{%- endif -%}
        {%- if section.settings.col3_link2_label != blank -%}<li><a href="{{ section.settings.col3_link2_url | default: 'https://archetypehair.com/#ingredients' }}">{{ section.settings.col3_link2_label }}</a></li>{%- endif -%}
        {%- if section.settings.col3_link3_label != blank -%}<li><a href="{{ section.settings.col3_link3_url | default: '/pages/ritual' }}">{{ section.settings.col3_link3_label }}</a></li>{%- endif -%}
        {%- if section.settings.col3_link4_label != blank -%}<li><a href="{{ section.settings.col3_link4_url | default: '/blogs/journal' }}">{{ section.settings.col3_link4_label }}</a></li>{%- endif -%}
        {%- if section.settings.col3_link5_label != blank -%}<li><a href="{{ section.settings.col3_link5_url | default: '/pages/contact' }}">{{ section.settings.col3_link5_label }}</a></li>{%- endif -%}
      </ul>
    </div>

    <!-- Support col -->
    <div class="footer-col">
      <h4>{{ section.settings.col4_title | default: 'Support' }}</h4>
      <ul>
        {%- if section.settings.col4_link1_label != blank -%}<li><a href="{{ section.settings.col4_link1_url | default: '/pages/faq' }}">{{ section.settings.col4_link1_label }}</a></li>{%- endif -%}
        {%- if section.settings.col4_link2_label != blank -%}<li><a href="{{ section.settings.col4_link2_url | default: '/pages/shipping-and-returns' }}">{{ section.settings.col4_link2_label }}</a></li>{%- endif -%}
        {%- if section.settings.col4_link3_label != blank -%}<li><a href="{{ section.settings.col4_link3_url | default: '/pages/privacy-policy' }}">{{ section.settings.col4_link3_label }}</a></li>{%- endif -%}
        {%- if section.settings.col4_link4_label != blank -%}<li><a href="{{ section.settings.col4_link4_url | default: '/pages/terms-and-conditions' }}">{{ section.settings.col4_link4_label }}</a></li>{%- endif -%}
        {%- if section.settings.col4_link5_label != blank -%}<li><a href="{{ section.settings.col4_link5_url | default: '/pages/contact' }}">{{ section.settings.col4_link5_label }}</a></li>{%- endif -%}
      </ul>
    </div>

  </div>

  <!-- Footer bottom bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-left">
      <p class="footer-copy">&copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright | default: shop.name }} &middot; {{ section.settings.rights | default: 'All rights reserved' }}</p>
      <div class="footer-langs">
        {%- if section.settings.lang1 != blank -%}<a href="{{ section.settings.lang1_url | default: '#' }}">{{ section.settings.lang1 }}</a>{%- endif -%}
        {%- if section.settings.lang2 != blank -%}<a href="{{ section.settings.lang2_url | default: '#' }}">{{ section.settings.lang2 }}</a>{%- endif -%}
        {%- if section.settings.lang3 != blank -%}<a href="{{ section.settings.lang3_url | default: '#' }}">{{ section.settings.lang3 }}</a>{%- endif -%}
        {%- if section.settings.lang4 != blank -%}<a href="{{ section.settings.lang4_url | default: '#' }}">{{ section.settings.lang4 }}</a>{%- endif -%}
        {%- if section.settings.lang5 != blank -%}<a href="{{ section.settings.lang5_url | default: '#' }}">{{ section.settings.lang5 }}</a>{%- endif -%}
      </div>
    </div>

    <!-- Payment icons — monochrome European -->
    <div class="footer-payments" aria-label="Accepted payment methods">
      {%- if section.settings.show_visa -%}
      <span class="pay-icon" title="Visa"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="22" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="currentColor" letter-spacing="-0.5">VISA</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_mc -%}
      <span class="pay-icon" title="Mastercard"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><circle cx="19" cy="16" r="8.5" fill="currentColor" opacity=".75"/><circle cx="31" cy="16" r="8.5" fill="currentColor" opacity=".45"/><path d="M25 9.3a8.5 8.5 0 0 1 0 13.4A8.5 8.5 0 0 1 25 9.3z" fill="currentColor" opacity=".6"/></svg></span>
      {%- endif -%}
      {%- if section.settings.show_amex -%}
      <span class="pay-icon" title="American Express"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="15" text-anchor="middle" font-family="Arial,sans-serif" font-size="6.5" font-weight="bold" fill="currentColor" letter-spacing="0.6">AMERICAN</text><text x="25" y="23" text-anchor="middle" font-family="Arial,sans-serif" font-size="6.5" font-weight="bold" fill="currentColor" letter-spacing="0.6">EXPRESS</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_paypal -%}
      <span class="pay-icon" title="PayPal"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="21" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="currentColor" letter-spacing="0.3">PayPal</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_applepay -%}
      <span class="pay-icon" title="Apple Pay"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="21" text-anchor="middle" font-family="-apple-system,Arial,sans-serif" font-size="10" font-weight="600" fill="currentColor" letter-spacing="0.2"> Pay</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_googlepay -%}
      <span class="pay-icon" title="Google Pay"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="21" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" font-weight="500" fill="currentColor" letter-spacing="0.2">G Pay</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_ideal -%}
      <span class="pay-icon" title="iDEAL"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="21" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="currentColor" letter-spacing="-0.3">iDEAL</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_bancontact -%}
      <span class="pay-icon" title="Bancontact"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="14" text-anchor="middle" font-family="Arial,sans-serif" font-size="6" font-weight="bold" fill="currentColor" letter-spacing="0.3">BAN</text><text x="25" y="23" text-anchor="middle" font-family="Arial,sans-serif" font-size="6" font-weight="bold" fill="currentColor" letter-spacing="0.3">CONTACT</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_klarna -%}
      <span class="pay-icon" title="Klarna"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="21" text-anchor="middle" font-family="Arial,sans-serif" font-size="10" font-weight="bold" fill="currentColor" letter-spacing="0.5">Klarna</text></svg></span>
      {%- endif -%}
      {%- if section.settings.show_sepa -%}
      <span class="pay-icon" title="SEPA Bank Transfer"><svg viewBox="0 0 50 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="50" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity=".25"/><text x="25" y="14" text-anchor="middle" font-family="Arial,sans-serif" font-size="7.5" font-weight="bold" fill="currentColor" letter-spacing="1">SEPA</text><text x="25" y="24" text-anchor="middle" font-family="Arial,sans-serif" font-size="5.5" font-weight="400" fill="currentColor" letter-spacing="0.4" opacity=".7">BANK TRANSFER</text></svg></span>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo",      "label": "Logo (light version)" },
    { "type": "textarea",     "id": "about",     "label": "Brand description" },
    { "type": "header", "content": "Social Links" },
    { "type": "url", "id": "instagram",  "label": "Instagram URL" },
    { "type": "url", "id": "tiktok",     "label": "TikTok URL" },
    { "type": "url", "id": "pinterest",  "label": "Pinterest URL" },
    { "type": "url", "id": "youtube",    "label": "YouTube URL" },
    { "type": "header", "content": "Column 2 — Shop" },
    { "type": "text", "id": "col2_title", "label": "Column title", "default": "Shop" },
    { "type": "header", "content": "Column 3" },
    { "type": "text", "id": "col3_title",      "label": "Column title",   "default": "Archetype" },
    { "type": "text", "id": "col3_link1_label","label": "Link 1 label",   "default": "Our Story" },
    { "type": "url",  "id": "col3_link1_url",  "label": "Link 1 URL" },
    { "type": "text", "id": "col3_link2_label","label": "Link 2 label",   "default": "Ingredients" },
    { "type": "url",  "id": "col3_link2_url",  "label": "Link 2 URL" },
    { "type": "text", "id": "col3_link3_label","label": "Link 3 label",   "default": "The Ritual" },
    { "type": "url",  "id": "col3_link3_url",  "label": "Link 3 URL" },
    { "type": "text", "id": "col3_link4_label","label": "Link 4 label",   "default": "Journal" },
    { "type": "url",  "id": "col3_link4_url",  "label": "Link 4 URL" },
    { "type": "text", "id": "col3_link5_label","label": "Link 5 label",   "default": "Contact" },
    { "type": "url",  "id": "col3_link5_url",  "label": "Link 5 URL" },
    { "type": "header", "content": "Column 4" },
    { "type": "text", "id": "col4_title",      "label": "Column title",   "default": "Support" },
    { "type": "text", "id": "col4_link1_label","label": "Link 1 label",   "default": "FAQ" },
    { "type": "url",  "id": "col4_link1_url",  "label": "Link 1 URL" },
    { "type": "text", "id": "col4_link2_label","label": "Link 2 label",   "default": "Shipping and Returns" },
    { "type": "url",  "id": "col4_link2_url",  "label": "Link 2 URL" },
    { "type": "text", "id": "col4_link3_label","label": "Link 3 label",   "default": "Privacy Policy" },
    { "type": "url",  "id": "col4_link3_url",  "label": "Link 3 URL" },
    { "type": "text", "id": "col4_link4_label","label": "Link 4 label",   "default": "Terms and Conditions" },
    { "type": "url",  "id": "col4_link4_url",  "label": "Link 4 URL" },
    { "type": "text", "id": "col4_link5_label","label": "Link 5 label" },
    { "type": "url",  "id": "col4_link5_url",  "label": "Link 5 URL" },
    { "type": "header", "content": "Bottom Bar" },
    { "type": "text", "id": "copyright", "label": "Copyright name",   "default": "Archetype® Hair" },
    { "type": "text", "id": "rights",    "label": "Rights text",      "default": "All rights reserved" },
    { "type": "header", "content": "Language switcher (up to 5)" },
    { "type": "text", "id": "lang1", "label": "Lang 1", "default": "EN" }, { "type": "url", "id": "lang1_url", "label": "Lang 1 URL" },
    { "type": "text", "id": "lang2", "label": "Lang 2", "default": "FR" }, { "type": "url", "id": "lang2_url", "label": "Lang 2 URL" },
    { "type": "text", "id": "lang3", "label": "Lang 3", "default": "NL" }, { "type": "url", "id": "lang3_url", "label": "Lang 3 URL" },
    { "type": "text", "id": "lang4", "label": "Lang 4", "default": "DE" }, { "type": "url", "id": "lang4_url", "label": "Lang 4 URL" },
    { "type": "text", "id": "lang5", "label": "Lang 5", "default": "PT" }, { "type": "url", "id": "lang5_url", "label": "Lang 5 URL" },
    { "type": "header", "content": "Payment Methods" },
    { "type": "checkbox", "id": "show_visa",       "label": "Visa",             "default": true },
    { "type": "checkbox", "id": "show_mc",         "label": "Mastercard",       "default": true },
    { "type": "checkbox", "id": "show_amex",       "label": "American Express", "default": true },
    { "type": "checkbox", "id": "show_paypal",     "label": "PayPal",           "default": true },
    { "type": "checkbox", "id": "show_applepay",   "label": "Apple Pay",        "default": true },
    { "type": "checkbox", "id": "show_googlepay",  "label": "Google Pay",       "default": true },
    { "type": "checkbox", "id": "show_ideal",      "label": "iDEAL",            "default": true },
    { "type": "checkbox", "id": "show_bancontact", "label": "Bancontact",       "default": true },
    { "type": "checkbox", "id": "show_klarna",     "label": "Klarna",           "default": true },
    { "type": "checkbox", "id": "show_sepa",       "label": "SEPA Bank Transfer","default": true },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "bg_color", "label": "Background color" }
  ]
}
{% endschema %}

{%- liquid
  assign search_q     = search.terms | escape
  assign result_count = search.results_count
  assign per_page     = 12
-%}

<section class="search-results-section">
  <div class="search-results-inner">

    <!-- Search bar -->
    <div class="search-results-hero">
      <p class="eyebrow">Search</p>
      <h1 class="search-results-title">
        {%- if search_q != blank -%}
          Results for <em>{{ search_q }}</em>
        {%- else -%}
          What are you looking for?
        {%- endif -%}
      </h1>

      <form action="/search" method="get" class="search-results-form" role="search">
        <input type="hidden" name="type" value="product">
        <div class="search-results-input-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            type="search"
            name="q"
            value="{{ search_q }}"
            placeholder="Search products, ingredients…"
            autocomplete="off"
            class="search-results-input"
            aria-label="Search products"
          >
          <button type="submit" class="search-results-submit">Search</button>
        </div>
      </form>

      {%- if search_q != blank -%}
        <p class="search-results-count">
          {%- if result_count == 0 -%}
            No results found
          {%- elsif result_count == 1 -%}
            1 product found
          {%- else -%}
            {{ result_count }} products found
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>

    {%- if search_q != blank -%}
      {%- if result_count > 0 -%}

        <div class="search-results-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- liquid
                assign product = item
                assign product_tag = ''
                assign tag_accent  = false
                for tag in product.tags
                  assign tag_lower = tag | downcase
                  if tag_lower == 'base' or tag_lower == 'booster' or tag_lower == 'kit'
                    assign product_tag = tag
                    if tag_lower == 'booster' or tag_lower == 'kit'
                      assign tag_accent = true
                    endif
                    break
                  endif
                endfor
              -%}
              <a href="{{ product.url }}" class="product-card reveal">
                <div class="product-img">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape | default: product.title }}"
                      width="600"
                      loading="lazy">
                  {%- else -%}
                    <div class="product-img-placeholder">
                      <svg viewBox="0 0 60 60" fill="none"><rect width="60" height="60" fill="var(--cream-2)"/><path d="M20 40L28 28l6 8 5-6 9 10H20z" fill="var(--muted)" opacity=".4"/><circle cx="38" cy="22" r="4" fill="var(--muted)" opacity=".4"/></svg>
                    </div>
                  {%- endif -%}
                  {%- unless product_tag == blank -%}
                    <span class="product-tag{% if tag_accent %} accent{% endif %}">{{ product_tag }}</span>
                  {%- endunless -%}
                  {%- if product.compare_at_price > product.price -%}
                    <span class="product-badge-sale">Sale</span>
                  {%- endif -%}
                </div>
                <div class="product-info">
                  <h2 class="product-name">{{ product.title }}</h2>
                  <div class="product-stars">
                    {%- if product.metafields.reviews.rating.value != blank -%}
                      {%- assign rating_val   = product.metafields.reviews.rating.value | times: 1.0 -%}
                      {%- assign rating_count = product.metafields.reviews.rating_count.value | default: 0 -%}
                      {%- assign full_stars   = rating_val | floor -%}
                      {%- assign half_star    = rating_val | minus: full_stars -%}
                      {%- assign empty_stars  = 5 | minus: full_stars -%}
                      {%- if half_star >= 0.4 -%}{%- assign empty_stars = empty_stars | minus: 1 -%}{%- endif -%}
                      {%- for i in (1..full_stars) -%}<span class="star star-full">&#9733;</span>{%- endfor -%}
                      {%- if half_star >= 0.4 -%}<span class="star star-half">&#9733;</span>{%- endif -%}
                      {%- for i in (1..empty_stars) -%}<span class="star star-empty">&#9734;</span>{%- endfor -%}
                      {%- if rating_count > 0 -%}<span class="product-review-count">({{ rating_count }})</span>{%- endif -%}
                    {%- else -%}
                      <span class="star star-full">&#9733;</span><span class="star star-full">&#9733;</span>
                      <span class="star star-full">&#9733;</span><span class="star star-full">&#9733;</span>
                      <span class="star star-full">&#9733;</span>
                    {%- endif -%}
                  </div>
                  {%- if product.metafields.archetype.subtitle -%}
                    <p class="product-type">{{ product.metafields.archetype.subtitle }}</p>
                  {%- elsif product.product_type != blank -%}
                    <p class="product-type">{{ product.product_type }}</p>
                  {%- endif -%}
                  {%- if product.description != blank -%}
                    <p class="product-desc">{{ product.description | strip_html | truncate: 120 }}</p>
                  {%- endif -%}
                  <div class="product-footer">
                    <span class="product-price">
                      {%- if product.price_varies -%}
                        From {{ product.price_min | money }}
                      {%- else -%}
                        {{ product.price | money }}
                      {%- endif -%}
                    </span>
                    <span class="btn-add">View &rarr;</span>
                  </div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
        {% paginate search.results by per_page %}
          <div class="search-pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination-btn">&larr; Previous</a>
            {%- endif -%}
            <span class="pagination-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination-btn">Next &rarr;</a>
            {%- endif -%}
          </div>
        {% endpaginate %}
        {%- endif -%}

      {%- else -%}
        <!-- No results -->
        <div class="search-no-results-page">
          <div class="search-no-results-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <h2 class="search-no-results-title">No results for &ldquo;{{ search_q }}&rdquo;</h2>
          <p class="search-no-results-body">Try a different search term, or browse our full collection.</p>
          <a href="/collections/all" class="btn-dark">Browse All Products &rarr;</a>

          {%- if recommendations.performed -%}
          <div class="search-suggestions">
            <p class="search-suggestions-label">You might also like</p>
            <div class="search-suggestions-grid">
              {%- for product in recommendations.products limit: 4 -%}
                <a href="{{ product.url }}" class="product-card">
                  <div class="product-img">
                    {%- if product.featured_image -%}
                      <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" width="400" loading="lazy">
                    {%- endif -%}
                  </div>
                  <div class="product-info">
                    <h3 class="product-name">{{ product.title }}</h3>
                    <div class="product-footer">
                      <span class="product-price">{{ product.price | money }}</span>
                    </div>
                  </div>
                </a>
              {%- endfor -%}
            </div>
          </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Search Results",
  "settings": []
}
{% endschema %}

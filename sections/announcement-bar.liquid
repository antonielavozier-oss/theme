<div class="announce-bar" {% if section.settings.bg_color != blank %}style="background:{{ section.settings.bg_color }}"{% endif %}>
  <div class="announce-scroll">
    {%- assign msgs = "" -%}
    {%- if section.settings.message_1 != blank -%}{%- assign msgs = msgs | append: section.settings.message_1 | append: "|||" -%}{%- endif -%}
    {%- if section.settings.message_2 != blank -%}{%- assign msgs = msgs | append: section.settings.message_2 | append: "|||" -%}{%- endif -%}
    {%- if section.settings.message_3 != blank -%}{%- assign msgs = msgs | append: section.settings.message_3 | append: "|||" -%}{%- endif -%}
    {%- if section.settings.message_4 != blank -%}{%- assign msgs = msgs | append: section.settings.message_4 | append: "|||" -%}{%- endif -%}
    {%- assign items = msgs | split: "|||" -%}
    <span>
      {%- for item in items -%}{%- unless item == blank -%}{{ item }}&nbsp;&nbsp;&bull;&nbsp;&nbsp;{%- endunless -%}{%- endfor -%}
      {%- for item in items -%}{%- unless item == blank -%}{{ item }}&nbsp;&nbsp;&bull;&nbsp;&nbsp;{%- endunless -%}{%- endfor -%}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "header", "content": "Messages" },
    { "type": "text", "id": "message_1", "label": "Message 1", "default": "Free shipping in Belgium on all orders" },
    { "type": "text", "id": "message_2", "label": "Message 2", "default": "Free European shipping on orders above 75 EUR" },
    { "type": "text", "id": "message_3", "label": "Message 3", "default": "Delivered within 1-3 working days" },
    { "type": "text", "id": "message_4", "label": "Message 4", "default": "Natural. Sustainable. Made for every hair type." },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#2b2218" }
  ]
}
{% endschema %}

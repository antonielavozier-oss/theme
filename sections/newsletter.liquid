<section class="newsletter-section" id="newsletter">
  <div class="newsletter-inner">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="section-title">{{ section.settings.title }}<br>{{ section.settings.title_2 }}</h2>
    {%- if section.settings.body != blank -%}
      <p class="body-text">{{ section.settings.body }}</p>
    {%- endif -%}
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="{{ section.settings.tag }}">
      <input type="hidden" name="contact[accepts_marketing]" value="true">
      <div class="newsletter-form">
        <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
        <input type="submit" value="{{ section.settings.btn_label }}">
      </div>
      {%- if form.posted_successfully? -%}
        <p class="newsletter-success">{{ section.settings.success_msg }}</p>
      {%- endif -%}
    {% endform %}
    {%- if section.settings.disclaimer != blank -%}
      <p class="newsletter-disclaimer">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Alchemist Circle" },
    { "type": "text", "id": "title", "label": "Title line 1", "default": "From customer" },
    { "type": "text", "id": "title_2", "label": "Title line 2", "default": "to alchemist." },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Rituals, discoveries, and the ancient wisdom of personalized haircare. Join our circle." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Join" },
    { "type": "text", "id": "success_msg", "label": "Success message", "default": "Welcome to the circle." },
    { "type": "text", "id": "tag", "label": "Customer tag", "default": "newsletter" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer text", "default": "No spam. Unsubscribe anytime." }
  ]
}
{% endschema %}
